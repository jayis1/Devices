  (symbol (lib_id "LED:LED_660nm") (at 270 140 0) (uuid "led-660"))
  (property "MPN" "VLMR660nm" (at 270 140 0))      ; PWM=GPIO21
  (symbol (lib_id "LED:LED_850nm") (at 300 140 0) (uuid "led-850"))
  (property "MPN" "VSMY9851-850nm" (at 300 140 0)) ; PWM=GPIO33

  ; ─── VL53L1X ToF distance (focus) ───
  (symbol (lib_id "Sensor_Distance:VL53L1X") (at 270 180 0) (uuid "s-vl53l1x"))
  (property "MPN" "VL53L1XCBV0JC" (at 270 180 0))
