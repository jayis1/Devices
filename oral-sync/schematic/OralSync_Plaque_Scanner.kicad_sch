  ; ─── Power: 1200mAh Li-Po + TP4056 USB-C charger → 3.3V + 5V camera ───
  (symbol (lib_id "Connector:USB_C_Receptacle") (at 30 30 0) (uuid "pwr-usb"))
  (symbol (lib_id "Battery:Battery_Cell") (at 30 65 0) (uuid "bat-lipo"))
  (property "MPN" "103040 1200mAh Li-Po" (at 30 65 0))
  (symbol (lib_id "Battery_Charger:TP4056") (at 60 45 0) (uuid "chg-ic"))
  (property "MPN" "TP4056" (at 60 45 0))
  (symbol (lib_id "Regulator_Switching:MT3608") (at 100 45 0) (uuid "vreg-boost"))
  (property "MPN" "MT3608" (at 100 45 0))  ; → 5V for camera
  (symbol (lib_id "Regulator_Linear:AP2112K-3.3") (at 130 45 0) (uuid "vreg-ldo"))
  (property "MPN" "AP2112K-3.3" (at 130 45 0))

  ; ─── ESP32-S3 (dual-core 240MHz, DVP camera, vector instr) ───
  (symbol (lib_id "RF_Module:ESP32-S3-WROOM-1") (at 160 90 0) (uuid "mcu-esp32s3"))
  (property "MPN" "ESP32-S3-WROOM-1-N16R8" (at 160 90 0))
  ; GPIO0=VSYNC GPIO1=HREF GPIO2=PCLK GPIO3=XCLK(20MHz)
  ; GPIO4-11=D0-D7 (8-bit DVP) GPIO12=PWDN GPIO13=RESET
  ; GPIO14=SDA(SCCB) GPIO15=SCL  GPIO16=VL53 XSHUT GPIO17=VL53 INT
  ; GPIO18=405nm PWM GPIO19=470nm GPIO20=525nm GPIO21=660nm
  ; GPIO33=850nm GPIO34-35=SHT40 I2C GPIO36-39=ST7789 SPI GPIO40=buzzer
  ; GPIO41=charge status GPIO42=battery ADC1

  ; ─── OV5640 autofocus camera (5MP, DVP 8-bit) ───
  (symbol (lib_id "Sensor_Image:OV5640") (at 270 50 0) (uuid "cam-ov5640"))
  (property "MPN" "OV5640-AutoFocus" (at 270 50 0))
  ; D0-D7=GPIO4-11  VSYNC=GPIO0  HREF=GPIO1  PCLK=GPIO2  XCLK=GPIO3
  ; PWDN=GPIO12  RESET=GPIO13  SDA=GPIO14  SCL=GPIO15

  ; ─── Multispectral LED ring (5 bands + white) ───
  (symbol (lib_id "LED:LED_405nm") (at 270 110 0) (uuid "led-405"))
