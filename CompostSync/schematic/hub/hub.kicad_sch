  ; Components would be placed here in full KiCad format
  ; This is a structural representation of the schematic netlist

  ; U1: ESP32-WROOM-32E
  ;   VCC → +3V3 (pin 2)
  ;   GND → GND (pin 1, 15, 38)
  ;   GPIO14 → SPI_MOSI (SX1262)
  ;   GPIO12 → SPI_MISO (SX1262)
  ;   GPIO13 → SPI_SCK (SX1262)
  ;   GPIO15 → SX_NSS
  ;   GPIO2  → SX_RST
  ;   GPIO4  → SX_DIO1
  ;   GPIO5  → SX_BUSY
  ;   GPIO21 → I2C_SDA (OLED, BME280)
  ;   GPIO22 → I2C_SCL (OLED, BME280)
  ;   GPIO19 → SD_MISO (SPI2)
  ;   GPIO23 → SD_MOSI (SPI2)
  ;   GPIO18 → SD_SCK (SPI2)
  ;   GPIO25 → SD_CS
  ;   GPIO26 → LED_WS2812
  ;   GPIO27 → BTN_MODE

  ; U2: SX1262 LoRa Module
  ;   MOSI  ← GPIO14
  ;   MISO  → GPIO12
  ;   SCK   ← GPIO13
  ;   NSS   ← GPIO15
  ;   RST   ← GPIO2
  ;   DIO1  → GPIO4
  ;   BUSY  → GPIO5
  ;   ANT   → 868MHz antenna
  ;   VCC   → +3V3
  ;   GND   → GND

  ; U3: SSD1306 OLED (I2C)
  ;   SDA ← GPIO21
  ;   SCL ← GPIO22
  ;   VCC → +3V3
  ;   GND → GND

  ; U4: BME280 (I2C, addr 0x76)
  ;   SDA ← GPIO21
  ;   SCL ← GPIO22
  ;   VCC → +3V3
  ;   GND → GND

  ; U5: microSD Socket (SPI2)
  ;   MISO → GPIO19
  ;   MOSI ← GPIO23
  ;   SCK  ← GPIO18
  ;   CS   ← GPIO25
  ;   VCC  → +3V3
  ;   GND  → GND

  ; U6: AP2112 LDO (3.3V)
  ;   IN  ← +5V (USB-C or solar)
  ;   OUT → +3V3
  ;   GND → GND

  ; U7: TP4056 (battery charger)
  ;   VCC ← +5V (USB-C)
  ;   BAT → VBAT (18650)
  ;   GND → GND

  ; U8/U9: DW01A + FS8205A (battery protection)
  ;   Between TP4056 BAT and 18650 cell

  ; D1: WS2812B LED ← GPIO26

  ; J1: USB-C → +5V

  ; BT1: 18650 holder → VBAT

  ; PV1: Solar panel → TP4056 input

)