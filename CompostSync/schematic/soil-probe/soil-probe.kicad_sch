(kicad_p
  (version 20231120)
  (generator "compostsync")
  (paper "A4")
  (title_block
    (title "CompostSync Soil Probe Schematic")
    (date "2026-06-27")
    (rev "1.0")
    (company "CompostSync")
    (comment 1 "RP2040 (Pico) + HM-19 BLE + SSD1306 OLED + DS18B20×4 + SCD41 + MCP3201 pH")
    (comment 2 "Battery powered, IP65 wand enclosure")
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "+3V3")
  (net 3 "VBAT")
  (net 10 "I2C0_SDA")
  (net 11 "I2C0_SCL")
  (net 12 "I2C1_SDA")
  (net 13 "I2C1_SCL")
  (net 20 "OW_1")
  (net 21 "OW_2")
  (net 22 "OW_3")
  (net 23 "OW_4")
  (net 24 "ADC0_MOIST1")
  (net 25 "ADC1_MOIST2")
  (net 26 "ADC2_MOIST3")
  (net 27 "SPI_CLK")
  (net 28 "SPI_DOUT")
  (net 29 "SPI_CS")
  (net 30 "UART_TX")
  (net 31 "UART_RX")
  (net 32 "BTN")
  (net 33 "LED"))

  ; Pin assignments (RP2040 / Pico):
  ; GP0  → I2C0_SDA (OLED 0x3C)
  ; GP1  → I2C0_SCL (OLED)
  ; GP2  → OW_1 (DS18B20 #1 at 5cm)
  ; GP3  → OW_2 (DS18B20 #2 at 15cm)
  ; GP4  → OW_3 (DS18B20 #3 at 25cm)
  ; GP5  → OW_4 (DS18B20 #4 at 35cm)
  ; GP6  → SPI_CLK (MCP3201 for pH)
  ; GP7  → SPI_DOUT (MCP3201)
  ; GP8  → SPI_CS (MCP3201)
  ; GP10 → UART_TX (HM-19 BLE)
  ; GP11 → UART_RX (HM-19 BLE)
  ; GP14 → I2C1_SDA (SCD41 via TCA9548A mux)
  ; GP15 → I2C1_SCL (SCD41 via mux)
  ; GP16 → BTN (button, active low)
  ; GP17 → LED (status)
  ; GP26 → ADC0 (moisture #1)
  ; GP27 → ADC1 (moisture #2)
  ; GP28 → ADC2 (moisture #3)

)