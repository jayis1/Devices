  ; Pin assignments:
  ; GPIO14 → SPI_MOSI (SX1262)
  ; GPIO12 → SPI_MISO (SX1262)
  ; GPIO13 → SPI_SCK (SX1262)
  ; GPIO15 → SX_NSS
  ; GPIO2  → SX_RST
  ; GPIO4  → SX_DIO1
  ; GPIO5  → SX_BUSY
  ; GPIO21 → I2C_SDA (SCD41)
  ; GPIO22 → I2C_SCL (SCD41)
  ; GPIO32 → DS18B20_1 (OneWire)
  ; GPIO33 → DS18B20_2 (OneWire)
  ; GPIO34 → DS18B20_3 (OneWire, input only)
  ; GPIO35 → MOIST_1_ADC (ADC1_CH7, input only)
  ; GPIO36 → MOIST_2_ADC (ADC1_CH0, input only)
  ; GPIO39 → MOIST_3_ADC (ADC1_CH3, input only)
  ; GPIO25 → MQ4_ADC (ADC2_CH8)
  ; GPIO26 → HX711_DOUT
  ; GPIO27 → HX711_SCK
  ; GPIO18 → SERVO_PWM (LEDC)
  ; GPIO19 → LED_WS2812

